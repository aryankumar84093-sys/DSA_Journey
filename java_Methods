//Decimal to Binary Conversion
public class DecimatToBinary {
    public static void decToBin(int n){
        int bin = 0;
        while(n!=0){
            int rem = n % 2;
            n = n/2;
            bin = (bin*10) + rem;
        }
        System.out.println(bin);
    }
    public static void main(String args[]){
        decToBin(7);
    }
}

