//Binary to Decimal Conversion
public class BinaryToDecimal {
    public static void binaryToDec(int n){
        int pow=0;
        int dec = 0;
        while(n!=0){
            int digit = n % 10;
            n /= 10;
            dec = dec + (digit * (int)(Math.pow(2,pow)));
            pow++;
        }
        System.out.println(dec);
    }
    public static void main(String args[]){
        binaryToDec(11111);
    }
}
